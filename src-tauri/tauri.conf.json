{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "rawdog",
  "version": "0.1.0",
  "identifier": "com.rawdog.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "rawdog",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' rawdog: asset: http://asset.localhost https://asset.localhost tauri: http://tauri.localhost;",
      "assetProtocol": {
        "scope": ["**", "/var/folders/**", "/private/var/folders/**", "/tmp/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:path:default",
    "core:image:default",
    "dialog:default",
    "allow-get-images",
    "allow-update-status",
    "allow-finish-culling",
    "allow-start-scanning"
  ]
}
